# Copy this file to .env and fill in the real values.
# .env is gitignored; .env.example is committed.
#
# Docker Compose auto-loads .env from the directory containing the compose file.

# ----- Apple Music -----
# Required when using: docker compose -f docker-compose.yml -f docker-compose.apple-music.yml up

# Team ID from developer.apple.com (10 chars, alphanumeric)
APPLE_TEAM_ID=XXXXXXXXXX

# Key ID from developer.apple.com (10 chars, shown on the key's page)
APPLE_KEY_ID=XXXXXXXXXX

# Host path to the .p8 private key (resolved relative to the compose file dir).
# The file must exist; Compose binds it read-only into the container.
APPLE_P8_HOST_PATH=./control-plane/secrets/AuthKey_XXXXXXXXXX.p8

# Optional tuning
# APPLE_TOKEN_TTL_SECONDS=2592000            # 30 days (Apple max: 15552000 = 180 days)
# APPLE_TOKEN_REFRESH_BUFFER_SECONDS=86400   # re-sign if remaining TTL < 24h
